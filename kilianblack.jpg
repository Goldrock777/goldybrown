://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2VwaG9yYQ/049365ae-a843-5204-9bff-bbaaf5376375","isIncentivizedReview":true},{"reviewId":"184174962","photoId":"12189142","thumbnailImageUrl":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2VwaG9yYQ/3b152a14-c9ad-5cd4-9a99-816f028995c8","isIncentivizedReview":true},{"reviewId":"184144792","photoId":"12185695","thumbnailImageUrl":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2VwaG9yYQ/c1da0e83-a4cc-5aea-a997-611378e8125c","isIncentivizedReview":true},{"reviewId":"184134815","photoId":"12184496","thumbnailImageUrl":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2VwaG9yYQ/0e6ccff7-f68b-5c3f-a12d-051b07e015af","isIncentivizedReview":true},{"reviewId":"184134815","photoId":"12184497","thumbnailImageUrl":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2VwaG9yYQ/0f0217b1-2802-50b3-ae01-fb1c5c141c04","isIncentivizedReview":true},{"reviewId":"184094395","photoId":"12179760","thumbnailImageUrl":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2VwaG9yYQ/74f33420-4395-5bd2-bf8f-06f9efe8e952","isIncentivizedReview":true},{"reviewId":"184092972","photoId":"12179578","thumbnailImageUrl":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2VwaG9yYQ/da70a97f-6511-56f4-807e-3ff008feb5c0","isIncentivizedReview":true},{"reviewId":"184091375","photoId":"12179402","thumbnailImageUrl":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2VwaG9yYQ/1d4dc03e-2d09-5cb8-81a8-7a065fe1abb0","isIncentivizedReview":true}],"header1":"Black Phantom Eau de Parfum with Coffee & Sandalwood","redirect":null,"schemas":[{"@type":"ItemList","@context":"http://schema.org","itemListElement":[{"url":"https://www.sephora.com/ca/en/shop/makeup-cosmetics","name":"Makeup","@type":"SiteNavigationElement","position":1,"description":"Shop the best makeup now at Sephora and earn points with every purchase! Not yet a Beauty Insider? Join now for FREE!"},{"url":"https://www.sephora.com/ca/en/shop/skincare","name":"Skincare","@type":"SiteNavigationElement","position":2,"description":"Shop skincare products at Sephora. Find top-rated products from leading skincare brands to help target specific skin concerns and revitalize your look."},{"url":"https://www.sephora.com/ca/en/shop/hair-products","name":"Hair","@type":"SiteNavigationElement","position":3,"description":"Explore our top-rated hair care products at Sephora. Browse an unrivaled selection of shampoos, conditioners, styling products, hair color and more from top brands."},{"url":"https://www.sephora.com/ca/en/shop/fragrance","name":"Fragrance","@type":"SiteNavigationElement","position":4,"description":"Shop fragrances for women and men at Sephora. Find your favorite perfume or cologne or accentuate your style with a new scent."},{"url":"https://www.sephora.com/ca/en/shop/makeup-tools","name":"Tools & Brushes","@type":"SiteNavigationElement","position":5,"description":"Shop beauty tools and accessories at Sephora. Find top-rated makeup tools, brushes, applicators, spa tools and more from leading brands."},{"url":"https://www.sephora.com/ca/en/shop/bath-body","name":"Bath & Body","@type":"SiteNavigationElement","position":6,"description":"Shop bath & body products at Sephora. Find an unrivaled selection of the top moisturizers, cleansers, lotions, exfoliants, scrubs and more from top brands."},{"url":"https://www.sephora.com/ca/en/sale","name":"Sale","@type":"SiteNavigationElement","position":7,"description":"Makeup sales are always on at Sephora. Shop discounted makeup, skincare, fragrance and hair care products at Sephora today. Free shipping and samples available."}]},{"itemListElement":[{"item":{"name":"Fragrance","@id":"https://www.sephora.com/ca/en/shop/fragrance"},"@type":"ListItem","position":1},{"item":{"name":"Women","@id":"https://www.sephora.com/ca/en/shop/fragrances-for-women"},"@type":"ListItem","position":2},{"item":{"name":"Perfume","@id":"https://www.sephora.com/ca/en/shop/perfume"},"@type":"ListItem","position":3}],"@type":"BreadcrumbList","@context":"http://schema.org"},{"@type":"ProductGroup","@context":"http://schema.org","name":"Black Phantom Eau de Parfum with Coffee & Sandalwood","description":"Shop Black Phantom by Kilian at Sephora. This fragrance contains notes of rum, coffee, and sandalwood.","brand":{"@type":"Brand","name":"KILIAN Paris"},"image":"https://www.sephora.com/productimages/sku/s2320174-main-hero.jpg","@id":"https://www.sephora.com/ca/en/product/black-phantom-memento-mori-P429627","url":"https://www.sephora.com/ca/en/product/black-phantom-memento-mori-P429627","productGroupID":"P429627","category":"perfume","hasVariant":[{"@type":"Product","name":"Black Phantom Eau de Parfum with Coffee & Sandalwood","sku":"2320174","image":"https://www.sephora.com/productimages/sku/s2320174-main-hero.jpg","offers":{"@type":"Offer","price":"385.0","priceCurrency":"CAD","availability":"https://schema.org/InStock","seller":{"@type":"Organization","name":"Sephora"}}}],"aggregateRating":{"reviewCount":"163","bestRating":"5","ratingValue":"4.245398773006135","itemReviewed":{"name":null}},"reviews":[{"datePublished":"2025-09-30","@type":"Review","author":{"name":"klarajeon"},"name":null,"description":"This is the best perfume ever! I never blind buy any perfumes especially if it’s as expensive as this one. And to be clear I have a very particular taste in perfumes and have never found my signature scent but this perfume is something else. As soon as I sprayed it I knew it was the one and it will be a forever repurchase!!!","itemReviewed":{"name":null},"@id":"360909559","reviewRating":{"bestRating":"5","ratingValue":"5"}},{"datePublished":"2025-03-04","@type":"Review","author":{"name":"FlightMama"},"name":"Beautiful, smells so good!","description":"Love love love this perfume. I can see how it’s not for everyone, its smell is very unique. To me it smells warm, nutty, a dark gourmand and is perfect for fall/winter. It’s definitely unisex, my son and I both wear it well. Try before you buy, but this is my favorite","itemReviewed":{"name":null},"@id":"339472642","reviewRating":{"bestRating":"5","ratingValue":"5"}},{"datePublished":"2025-01-03","@type":"Review","author":{"name":"FAME93"},"name":"Awful","description":"Do not get this. Just go with angel share fellas.","itemReviewed":{"name":null},"@id":"331010452","reviewRating":{"bestRating":"5","ratingValue":"1"}},{"datePublished":"2024-08-13","@type":"Review","author":{"name":"sarbear22"},"name":"It’s Giving… Wood","description":"This perfume is very unique which I find refreshing as many perfumery’s seem to carry the same one note fragrance but just slap a new label on the bottle. This perfume is incredibly woody. It leans a little too woody for my liking. I adore sandalwood but it goes unbalanced without a note that can either balance it. It’s not leaning clean or sweet- just woody. For the price of this perfume, I expected to be blown away with something well balanced and wearable. Sadly I think this truly is a collectors fragrance and would satisfy a small niche of buyers.","itemReviewed":{"name":null},"@id":"316595742","reviewRating":{"bestRating":"5","ratingValue":"2"}},{"datePublished":"2024-08-11","@type":"Review","author":{"name":"krisfek"},"name":"Not for me unfortunately","description":"I was so excited to try out Sacred Wood by Kilian. As in really excited. But all I can say is I’m not impressed. It smells awful in my opinion. I don’t know what’s happening. It’s a strong scent and I gravitate towards strong scents but this is not for me. It’s way too serious and old. Not light, or fun or pretty. It would be better as a candle in my opinion.","itemReviewed":{"name":null},"@id":"316376781","reviewRating":{"bestRating":"5","ratingValue":"3"}},{"datePublished":"2024-06-24","@type":"Review","author":{"name":"licensedtolove"},"name":"Rich and deep","description":"This is rich, deep, and masculine leaning. When I initially received I was on the fence but now that it has sat for a few months it is super intoxicating! Glad I held onto it.","itemReviewed":{"name":null},"@id":"312706064","reviewRating":{"bestRating":"5","ratingValue":"4"}},{"datePublished":"2024-06-11","@type":"Review","author":{"name":"macademia"},"name":"Must try","description":"Phenomenal scent. Warm, coffee and chocolate is definitely pronounced on my skin and in the end it goes into skin musk. Love this scent and I find it original and exquisite. I would recommend a sample as it is a dark scent, definitely gourmand so you need to be a lover of that. On my skin is smells perfectly unisex, but some other women might find it masculin. I find it intoxicating. I definitely smell pronounced coffee and dark chocolate on me. Rum just after spraying, but I would not call this perfume boozy. Definitely not as Angel's Share( which I love too). After few hours tonka and praline comes, and after about 8 hours I smell musk. Delicious fragrance.","itemReviewed":{"name":null},"@id":"311569330","reviewRating":{"bestRating":"5","ratingValue":"5"}},{"datePublished":"2024-05-19","@type":"Review","author":{"name":"Fragluv"},"name":"Lovely Gourmand","description":"Black Phantom by Kilian is an exquisite fragrance—luxurious, deep, and mysterious. However, its high price tag is hard to justify. For the same enchanting experience at a fraction of the cost, try \"Casper\" by Klone Fragrances. It’s the exact same. You won’t be disappointed!","itemReviewed":{"name":null},"@id":"309791640","reviewRating":{"bestRating":"5","ratingValue":"5"}},{"datePublished":"2024-03-25","@type":"Review","author":{"name":"julesmeows"},"name":"AMAZING!!!","description":"OMG. This is my absolute favourite cologne on my boyfriend. Whenever he wears it, I instantly fall in love again and again!! Best he's ever worn! I could eat him up","itemReviewed":{"name":null},"@id":"275107041","reviewRating":{"bestRating":"5","ratingValue":"5"}},{"datePublished":"2023-12-28","@type":"Review","author":{"name":"karenoreilly"},"name":"Gorgeous fragrance!","description":"One of my all time favourites! I always get tons of compliments from everyone when I wear this! Even young children, tell me how much they love it! It’s slightly sweet, warm & spicy, sexy and  luxurious","itemReviewed":{"name":null},"@id":"267307787","reviewRating":{"bestRating":"5","ratingValue":"5"}}]}],"cxsContent":{"sid":"product_page","slug":"/","similarProductsComparison":{"sys":{"publishedVersion":6},"sid":"Similar_Products_en","renderingType":"ProductPage_SimilarProducts","featuresData":[{"type":"KeyValue","sid":"Similar_Products_Buttons_Our_Picks_en","key":"similar-products-test","value":"Best Match"},{"type":"KeyValue","sid":"Similar_Products_Buttons_Under_Price_en","key":"similar-products-1","value":"Under -insert-price-here-"},{"type":"KeyValue","sid":"Similar_Products_Buttons_Trending_en","key":"similar-products-4","value":"Trending"}]}}},"apiConfigurationData":{"enableMidPageBanner":true,"splitEDDConfiguration":{"isSplitEDDEnabled_US":true,"isSplitEDDEnabled_CA":true,"isSplitEDDEnabled":true},"impressionTracker":{"components":{"isEnabledForCMSBannerList":false,"isEnabledForCMSSoftLinks":false,"isEnabledForCMSRewardList":false,"isEnabledForCMSRecap":false,"isEnabledForCMSPromotionList":false,"isEnabledForCMSProductList":false},"isEnabledForBasketPage":true,"isEnabledForHomePage":true},"enableSMSOptInParameters":true,"unifiedOrderHistory":{"isEnabled":false,"minAppVersion":"26.3"},"preAuthEnabled":true,"isSendAccessToken":true,"isPPagesChatEnabled":true,"enableNGPLithiumToken":true,"isLMSStoreAPIEnabled":true,"shippingCountries":"JP|Japan|JPY|Japanese Yen|JPY,US|United States,CA|Canada|CAD|CANADA|$","isMyOffersModuleEnabled":true,"recConfig":"'[{\"key\":\"makeup\",\"pdpCompareAttrs\":[\"price\",\"rating\",\"benefits\",\"formulation\"],\"plpCompareAttrs\":[\"color\",\"sizes\",\"ratingsReviews\",{\"overview\":[\"benefits\",\"formulation\",\"ingredientsPreferences\"]},\"pickupDelivery\"]},{\"key\":\"skinCare\",\"pdpCompareAttrs\":[\"price\",\"rating\",{\"g