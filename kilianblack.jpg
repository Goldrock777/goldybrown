ta-comp="Interstice Interstice Loader " class="css-zyalgz"></div></div><script id="linkStore" type="text/json" data-comp="PageJSON ">{"page":{"product":{"targetUrl":"/product/black-phantom-memento-mori-P429627","seoName":"black-phantom-memento-mori-P429627","seoTitle":"Black Phantom - \"Memento Mori\" - KILIAN Paris | Sephora","seoMetaDescription":"Shop Black Phantom by Kilian at Sephora. This fragrance contains notes of rum, coffee, and sandalwood.","seoCanonicalUrl":"/product/black-phantom-memento-mori-P429627","enableNoindexMetaTag":false,"productId":"P429627","currentSku":{"targetUrl":"/product/black-phantom-memento-mori-P429627?skuId=2320174","skuId":"2320174","actionFlags":{"isAddToBasket":true,"backInStockReminderStatus":"notApplicable","backInStockPhoneReminderStatus":"notApplicable","myListStatus":"notAdded","isFullSizeSkuOrderable":false,"isEnrollToFlash":false,"showAddReview":true,"isKlarnaEligible":true,"isAfterpayEligible":true,"isPayPalPayLaterEligible":false},"alternateImages":[{"image250":"https://www.sephora.com/productimages/product/p429627-av-02-zoom.jpg?imwidth=250","altText":"KILIAN Paris Black Phantom Eau de Parfum with Coffee & Sandalwood in 1.7 oz/ 50 mL Image 2","imageUrl":"https://www.sephora.com/productimages/product/p429627-av-02-zoom.jpg"},{"image250":"https://www.sephora.com/productimages/product/p429627-av-1-zoom.jpg?imwidth=250","altText":"KILIAN Paris Black Phantom Eau de Parfum with Coffee & Sandalwood in 1.7 oz/ 50 mL Image 3","imageUrl":"https://www.sephora.com/productimages/product/p429627-av-1-zoom.jpg"}],"biExclusiveLevel":"none","brandName":"KILIAN Paris","displayName":"2320174 1.7 oz/ 50 mL Eau de Parfum Spray","freeShippingType":"freeShipping","freeShippingMessage":"free shipping","highlights":[{"id":"900103","altText":"Warm & Spicy Scent","name":"Warm & Spicy Scent","imageUrl":"/contentimages/highlights/warm-spicy-scent.svg"},{"id":"900105","altText":"Unisex/ Genderless Scent","name":"Unisex/ Genderless Scent","imageUrl":"/contentimages/highlights/unisex-genderless-scent.svg"}],"ingredientDesc":"Alcohol Denat., Fragrance (Parfum), Aqua/Water/Eau, Isoeugenol, BHT. <br><br>Please be aware that ingredient lists may change or vary from time to time. Please refer to the ingredient list on the product package you receive for the most up to date list of ingredients.","isAppExclusive":false,"isBiOnly":false,"isBiReward":false,"isEligible":false,"isFirstAccess":false,"isFree":false,"isFreeShippingSku":true,"isElectronic":false,"hawaiiHazmatFlag":false,"isLimitedEdition":false,"isLimitedTimeOffer":false,"isNew":false,"isOnlineOnly":false,"isOnlyFewLeft":false,"isOutOfStock":false,"isExternallySellable":false,"isRopisEligibleSku":true,"isPickUpEligibleSku":true,"isSephoraExclusive":false,"listPrice":"$385.00","maxPurchaseQuantity":10,"productName":"Black Phantom Eau de Parfum with Coffee & Sandalwood","refinements":{"formulationRefinements":["Spray"]},"skuRefinements":[{"key":"formulation","values":["spray"]},{"key":"fragranceFamily","values":["warmspicy"]},{"key":"fragranceType","values":["woodySpices"]}],"size":"1.7 oz/ 50 mL","skuImages":{"image250":"https://www.sephora.com/productimages/sku/s2320174-main-zoom.jpg?imwidth=250","altText":"KILIAN Paris - Black Phantom Eau de Parfum with Coffee & Sandalwood 1.7 oz/ 50 mL KILIAN Paris Black Phantom Eau de Parfum with Coffee & Sandalwood","imageUrl":"https://www.sephora.com/productimages/sku/s2320174-main-zoom.jpg"},"smallImage":"https://www.sephora.com/productimages/sku/s2320174+sw-62.jpg","type":"Standard","typeDisplayName":"Standard","variationType":"Size + Concentration + Formulation","variationTypeDisplayName":"Size + Concentration + Formulation","variationValue":"1.7 oz/ 50 mL Eau de Parfum Spray","isReplenishmentEligible":true,"replenishmentFreqNum":3,"replenishmentFreqType":"Months","replenishmentAdjuster":"5.00","replenishmentAdjusterType":"P","replenishmentAdjusterPrice":"$365.75","isReturnable":true,"isSameDayEligibleSku":true,"isPayPalPayLaterEligible":false},"parentCategory":{"categoryId":"cat60148","displayName":"Perfume","targetUrl":"/shop/perfume","url":"/catalog/categories/cat60148?sortBy=-1&currentPage=1&content=true","parentCategory":{"categoryId":"cat1230039","displayName":"Women","targetUrl":"/shop/fragrances-for-women","url":"/catalog/categories/cat1230039","parentCategory":{"categoryId":"cat160006","displayName":"Fragrance","targetUrl":"/shop/fragrance","url":"/catalog/categories/cat160006"}}},"productDetails":{"productId":"P429627","displayName":"Black Phantom Eau de Parfum with Coffee & Sandalwood","brand":{"brandId":"6240","url":"https://productgraph-prod.prod.internal.sephora.com:443/v1/catalog/brands/6240","description":"Heir to a long line of cognac makers and pioneers in luxury, Kilian Hennessy carried on the family tradition when he launched KILIAN Paris. The brand reflects his distinct personality and blends elegance with uncompromising sophistication. Discover this unique perfume collection rooted in art, culture, and history.","longDescription":"Heir to a long line of cognac makers and pioneers in luxury, Kilian Hennessy carried on the family tradition when he launched KILIAN Paris. The brand reflects his distinct personality and blends elegance with uncompromising sophistication. Discover this unique perfume collection rooted in art, culture, and history.","displayName":"KILIAN Paris","targetUrl":"/brand/kilian"},"heroImageAltText":"KILIAN Paris Black Phantom Eau de Parfum with Coffee & Sandalwood","imageAltText":"KILIAN Paris - Black Phantom Eau de Parfum with Coffee & Sandalwood","longDescription":"<p><strong>Fragrance Family:</strong> Warm & Spicy</p><p><br></p><p><strong>Scent Type:</strong> Woody Spices</p><p><br></p><p><strong>Key Notes:</strong> Rum, Coffee, Vetiver</p><p><br></p><p><strong>Fragrance Description: </strong>This fragrance contains notes of rum essence which creates the scent of strong coffee at its heart, balanced out by vetiver essence. Sugar cane and dark creamy sandalwood notes also sweeten an otherwise deadly splash of cyanide.</p><p><br></p><p><strong>About the Bottle:</strong> The bottle of this Cellars perfume can be refilled indefinitely, because as Kilian himself says, \"True luxury should last forever.\" This bottles is adorned with a distinctive black lacquer and meticulously engraved on each side with the representation of the Achilles' shield. Like Kilian Hennessy says, \"In perfumery, it is as much about seduction as it is about protection.\"</p><p><br></p><p><strong>About the Fragrance: </strong>Inspired by one of Kilian’s favorite gothic horror books, Phantom of the Opera, he wanted to create a fragrance that represents a “forbidden love.” To express these feelings of darkness and danger, this fragrance includes notes of coffee, bitter almond, and rum. </p>","lovesCount":24258,"rating":4.2454,"reviews":163,"shortDescription":"<p><strong>Fragrance Family:</strong> Warm & Spicy</p><p><br></p><p><strong>Scent Type:</strong> Woody Spices</p><p><br></p><p><strong>Key Notes:</strong> Rum, Coffee, Vetiver</p><p><br></p><p><strong>Fragrance Description: </strong>This fragrance contains notes of rum essence which creates the scent of strong coffee at its heart, balanced out by vetiver essence. Sugar cane and dark creamy sandalwood notes also sweeten an otherwise deadly splash of cyanide.</p><p><br></p><p><strong>About the Bottle:</strong> The bottle of this Cellars perfume can be refilled indefinitely, because as Kilian himself says, \"True luxury should last forever.\" This bottles is adorned with a distinc</p><p><br></p><p><br></p>","suggestedUsage":"<b>Suggested Usage:</b><br>-Fragrance is intensified by the warmth of your own body. Apply in the creases of your knees and elbows for a longer-lasting, stronger scent. <br>-After applying, avoid rubbing or dabbing skin. This breaks down the fragrance, causing it to wear off more quickly. <br>-If you prefer placing fragrance on your wrists, be sure to reapply after frequent hand-washing, as this tends to rinse off the scent. <br>-Replace fragrance after 12 months. Expired perfumes more than a year old lose the integrity of the original scent.<br><br><b> Eau de Toilette or Eau de Parfum?:</b> <br>The difference lies in the volume of perfume oil. While EDT contains five to nine percent, EDP contains more, usually eight to 14 percent. EDPs, therefore, last longer and smell more intense.","alternateImages":[{"image250":"https://www.sephora.com/productimages/product/p429627-av-02-zoom.jpg?imwidth=250","altText":"KILIAN Paris Black Phantom Eau de Parfum with Coffee & Sandalwood Image 2","imageUrl":"https://www.sephora.com/productimages/product/p429627-av-02-zoom.jpg"},{"image250":"https://www.sephora.com/productimages/product/p429627-av-1-zoom.jpg?imwidth=250","altText":"KILIAN Paris Black Phantom Eau de Parfum with Coffee & Sandalwood Image 3","imageUrl":"https://www.sephora.com/productimages/product/p429627-av-1-zoom.jpg"}]},"quickLookDescription":"A fragrance that contains notes of rum, coffee, and sandalwood. ","regularChildSkus":[{"targetUrl":"/product/black-phantom-memento-mori-P429627?skuId=2320174","skuId":"2320174","actionFlags":{"isAddToBasket":true,"backInStockReminderStatus":"notApplicable","backInStockPhoneReminderStatus":"notApplicable","myListStatus":"notAdded","isFullSizeSkuOrderable":false,"isEnrollToFlash":false,"showAddReview":true,"isKlarnaEligible":true,"isAfterpayEligible":true,"isPayPalPayLaterEligible":false},"alternateImages":[{"image250":"https://www.sephora.com/productimages/product/p429627-av-02-zoom.jpg?imwidth=250","altText":"KILIAN Paris Black Phantom Eau de Parfum with Coffee & Sandalwood in 1.7 oz/ 50 mL Image 2","imageUrl":"https://www.sephora.com/productimages/product/p429627-av-02-zoom.jpg"},{"image250":"https://www.sephora.com/productimages/product/p429627-av-1-zoom.jpg?imwidth=250","altText":"KILIAN Paris Black Phantom Eau de Parfum with Coffee & Sandalwood in 1.7 oz/ 50 mL Image 3","imageUrl":"https://www.sephora.com/productimages/product/p429627-av-1-zoom.jpg"}],"biExclusiveLevel":"none","brandName":"KILIAN Paris","displayName":"2320174 1.7 oz/ 50 mL Eau de Parfum Spray","freeShippingType":"freeShipping","freeShippingMessage":"free shipping","highlights":[{"id":"900103","altText":"Warm & Spicy Scent","name":"Warm & Spicy Scent","imageUrl":"/contentimages/highlights/warm-spicy-scent.svg"},{"id":"900105","altText":"Unisex/ Genderless Scent","name":"Unisex/ Genderless Scent","imageUrl":"/contentimages/highlights/unisex-genderless-scent.svg"}],"ingredientDesc":"Alcohol Denat., Fragrance (Parfum), Aqua/Water/Eau, Isoeugenol, BHT. <br><br>Please be aware that ingredient lists may change or vary from time to time. Please refer to the ingredient list on the product package you receive for the most up to date list of ingredients.","isAppExclusive":false,"isBiOnly":false,"isBiReward":false,"isEligible":false,"isFirstAccess":false,"isFree":false,"isFreeShippingSku":true,"isElectronic":false,"hawaiiHazmatFlag":false,"isLimitedEdition":false,"isLimitedTimeOffer":false,"isNew":false,"isOnlineOnly":false,"isOnlyFewLeft":false,"isOutOfStock":false,"isExternallySellable":false,"isRopisEligibleSku":true,"isPickUpEligibleSku":true,"isSephoraExclusive":false,"listPrice":"$385.00","maxPurchaseQuantity":10,"productName":"Black Phantom Eau de Parfum with Coffee & Sandalwood","refinements":{"formulationRefinements":["Spray"]},"skuRefinements":[{"key":"formulation","values":["spray"]},{"key":"fragranceFamily","values":["warmspicy"]},{"key":"fragranceType","values":["woodySpices"]}],"size":"1.7 oz/ 50 mL","skuImages":{"image250":"https://www.sephora.com/productimages/sku/s2320174-main-zoom.jpg?imwidth=250","altText":"KILIAN Paris Black Phantom Eau de Parfum with Coffee & Sandalwood in 1.7 oz/ 50 mL","imageUrl":"https://www.sephora.com/productimages/sku/s2320174-main-zoom.jpg"},"smallImage":"https://www.sephora.com/productimages/sku/s2320174+sw-62.jpg","type":"Standard","t